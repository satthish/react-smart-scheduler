{
  "name": "react-smart-scheduler",
  "version": "0.1.1",
  "description": "A production-ready, open-source React scheduler/calendar component with Day, Week, and Month views — drag-and-drop, resize, and a clean controlled-component API.",
  "author": {
    "name": "react-smart-scheduler contributors",
    "url": "https://github.com/yourname/react-smart-scheduler"
  },
  "license": "MIT",
  "homepage": "https://github.com/yourname/react-smart-scheduler#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourname/react-smart-scheduler.git"
  },
  "bugs": {
    "url": "https://github.com/yourname/react-smart-scheduler/issues"
  },
  "keywords": [
    "react",
    "scheduler",
    "calendar",
    "drag-and-drop",
    "dnd",
    "week-view",
    "month-view",
    "day-view",
    "events",
    "time-grid",
    "typescript",
    "react-component",
    "open-source"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/scheduler.css": "./dist/scheduler.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev":            "vite serve --config vite.demo.config.ts",
    "build":          "tsc -p tsconfig.lib.json && vite build",
    "build:demo":     "vite build --config vite.demo.config.ts",
    "preview":        "vite preview --config vite.demo.config.ts",
    "type-check":     "tsc --noEmit",
    "prepublishOnly": "npm run type-check && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "date-fns": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-dts": "^4.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
