{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "react-smart-scheduler": ["./src/index.ts"]
    }
  },
  "include": ["src", "demo"],
  "exclude": ["node_modules", "dist"]
}
